module time

import "time.h" as ctime

##if (defined __ALPINE__) {
    import "bits/alltypes.h" as alltypes
}

macro HTTP_TIME_FMT "%a, %d %b %Y %T GMT";
macro LOG_TIME_FMT  "%Y-%m-%d %H:%M:%S";
macro DATE_FMT "%Y-%m-%d";
macro TIME_FMT "%H:%M:%S";
macro DATETIME_FMT "%Y-%m-%d %H:%M:%S";

#if (defined __ALPINE__) {
    pub type time_t = alltypes.time_t
}
else {
    pub type time_t = ctime.time_t
}

pub enum DayOfWeek: i32 {
    @str("Sunday")
    Sunday = 0,
    @str("Monday")
    Monday = 1,
    @str("Tuesday")
    Tuesday = 2,
    @str("Wednesday")
    Wednesday = 3,
    @str("Thursday")
    Thursday = 4,
    @str("Friday")
    Friday = 5,
    @str("Saturday")
    Saturday = 6
}

pub enum Month: i32 {
    @str("January")
    January = 1,
    @str("February")
    February = 2,
    @str("March")
    March = 3,
    @str("April")
    April = 4,
    @str("May")
    May = 5,
    @str("June")
    June = 6,
    @str("July")
    July = 7,
    @str("August")
    August = 8,
    @str("September")
    September = 9,
    @str("October")
    October = 10,
    @str("November")
    November = 11,
    @str("December")
    December = 12
}

pub struct Years {
    value: i64

    @inline
    const func `as`[Unit](): Unit {
        #if #Unit == #Years {
            return Years{value: value}
        }
        else #if #Unit == #Months {
            return Months{value: value * 12}
        }
        else #if #Unit == #Days {
            return Days{value: value * 365}
        }
        else #if #Unit == #Hours {
            return Hours{value: value * 8760}
        }
        else #if #Unit == #Minutes {
            return Minutes{value: value * 525600}
        }
        else #if #Unit == #Seconds {
            return Seconds{value: value * 31536000}
        }
        else #if #Unit == #Millis {
            return Millis{value: value * 31536000000}
        }
        else #if #Unit == #i64 {
            return value
        }
        else {
            error!("unsupported type {t}", #Unit)
        }
    }

    const func `str`(os: &OutputStream) {
        os << value << " year" << (value == 1 ? "" : "s")
    }

    @inline
    const func `==`[Unit](other: Unit): bool {
        #if #Unit == #i64 {
            return value == other
        }
        else #if #Unit == #Years {
            return value == other.value
        }
        else #if #Unit == #Months {
            return (this as Months).value == other.value
        }
        else #if #Unit == #Days {
            return (this as Days).value == other.value
        }
        else #if #Unit == #Hours {
            return (this as Hours).value == other.value
        }
        else #if #Unit == #Minutes {
            return (this as Minutes).value == other.value
        }
        else #if #Unit == #Seconds {
            return (this as Seconds).value == other.value
        }
        else #if #Unit == #Millis {
            return (this as Millis).value == other.value
        }
        else {
            error!("unsupported type {t}", #Unit)
        }
    }

    @inline
    const func `!=`[Unit](other: Unit): bool {
        return !(this == other)
    }

    @inline
    const func `<`[Unit](other: Unit): bool {
        #if #Unit == #i64 {
            return value < other
        }
        else #if #Unit == #Years {
            return value < other.value
        }
        else #if #Unit == #Months {
            return (this as Months).value < other.value
        }
        else #if #Unit == #Days {
            return (this as Days).value < other.value
        }
        else #if #Unit == #Hours {
            return (this as Hours).value < other.value
        }
        else #if #Unit == #Minutes {
            return (this as Minutes).value < other.value
        }
        else #if #Unit == #Seconds {
            return (this as Seconds).value < other.value
        }
        else #if #Unit == #Millis {
            return (this as Millis).value < other.value
        }
        else {
            error!("unsupported type {t}", #Unit)
        }
    }

    @inline
    const func `>`[Unit](other: Unit): bool {
        #if #Unit == #i64 {
            return value > other
        }
        else #if #Unit == #Years {
            return value > other.value
        }
        else #if #Unit == #Months {
            return (this as Months).value > other.value
        }
        else #if #Unit == #Days {
            return (this as Days).value > other.value
        }
        else #if #Unit == #Hours {
            return (this as Hours).value > other.value
        }
        else #if #Unit == #Minutes {
            return (this as Minutes).value > other.value
        }
        else #if #Unit == #Seconds {
            return (this as Seconds).value > other.value
        }
        else #if #Unit == #Millis {
            return (this as Millis).value > other.value
        }
        else {
            error!("unsupported type {t}", #Unit)
        }
    }

    @inline
    const func `<=`[Unit](other: Unit): bool {
        return !(this > other)
    }

    @inline
    const func `>=`[Unit](other: Unit): bool {
        return !(this < other)
    }
}

